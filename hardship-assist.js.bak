  const EN_TO_ES_WORDS = {
    'because': 'porque', 'also': 'tambiÃ©n', 'currently': 'actualmente', 'and': 'y',
    'has': 'tiene', 'have': 'tienen', 'had': 'tuvo', 'problem': 'problema', 'problems': 'problemas',
