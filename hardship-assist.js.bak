  const ES_TO_EN_WORDS = {
    'y': 'and', 'que': 'that', 'las': 'the', 'los': 'the', 'la': 'the', 'el': 'the', 'un': 'a', 'una': 'a',
    'de': 'of', 'su': "the client's", 'sus': "the client's", 'porque': 'because', 'tambien': 'also', 
